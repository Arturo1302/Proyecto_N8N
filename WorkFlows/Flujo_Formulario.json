      {
        "parameters": {
          "method": "POST",
          "url": "https://openrouter.ai/api/v1/chat/completions",
          "sendHeaders": true,
          "headerParameters": {
            "parameters": [
              {
                "name": "Authorization",
                "value": "Bearer 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"
              },
              {
                "name": "Content-Type",
